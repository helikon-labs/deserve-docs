{
    "name": "deserve-docs",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "docusaurus": "docusaurus",
        "start": "docusaurus start",
        "build": "npm run gen-all-api-docs && docusaurus build",
        "swizzle": "docusaurus swizzle",
        "deploy": "docusaurus deploy",
        "clear": "docusaurus clear",
        "serve": "docusaurus serve",
        "write-translations": "docusaurus write-translations",
        "write-heading-ids": "docusaurus write-heading-ids",
        "typecheck": "tsc",
        "format:check": "prettier . --check",
        "format": "prettier . --write",
        "gen-all-api-docs": "docusaurus gen-api-docs all",
        "regen-all-api-docs": "docusaurus clean-api-docs all && docusaurus gen-api-docs all",
        "clean-all-api-docs": "docusaurus clean-api-docs all",
        "gen-all-api-docs:version": "docusaurus gen-api-docs:version all",
        "clean-all-api-docs:version": "docusaurus clean-api-docs:version all",
        "scripts": "tsx scripts/index.ts"
    },
    "dependencies": {
        "@docusaurus/core": "3.10.0",
        "@docusaurus/faster": "3.10.0",
        "@docusaurus/preset-classic": "3.10.0",
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-brands-svg-icons": "^7.2.0",
        "@fortawesome/free-regular-svg-icons": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/react-fontawesome": "^3.3.0",
        "@mdx-js/react": "^3.1.1",
        "clsx": "^2.1.1",
        "docusaurus-plugin-openapi-docs": "^5.0.0",
        "docusaurus-theme-openapi-docs": "^5.0.0",
        "prism-react-renderer": "^2.4.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "rehype-katex": "^7.0.1",
        "remark-math": "^6.0.0"
    },
    "devDependencies": {
        "@docusaurus/module-type-aliases": "3.10.0",
        "@docusaurus/tsconfig": "3.10.0",
        "@docusaurus/types": "3.10.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "~6.0.2"
    },
    "overrides": {
        "node-forge": ">=1.3.2",
        "glob": ">=10.5.0",
        "gray-matter": {
            "js-yaml": "^3.14.1"
        },
        "docusaurus-plugin-openapi-docs": {
            "js-yaml": "^4.1.1"
        }
    },
    "browserslist": {
        "production": [
            ">0.5%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 3 chrome version",
            "last 3 firefox version",
            "last 5 safari version"
        ]
    },
    "engines": {
        "node": ">=20.0"
    }
}
